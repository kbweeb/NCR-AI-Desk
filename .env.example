# =============================================================================
# NCR AI Desk — copy to .env and fill in values:
#   copy .env.example .env
# =============================================================================

# --- Live AI (required for chat, weather, news) ---
# Get a key: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your-perplexity-api-key
# PERPLEXITY_MODEL=sonar
# PERPLEXITY_DOCUMENT_MODEL=sonar
# PERPLEXITY_MAX_TOKENS=1024
# PERPLEXITY_DOCUMENT_MAX_TOKENS=4096

# --- Qdrant Cloud (optional — semantic search over company directory) ---
QDRANT_URL=https://your-cluster-id.region.gcp.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=ncr-desk-kb

# --- Rust API (port 8090) ---
# AI_DESK_BIND=127.0.0.1:8090
# AI_DESK_DATA_DIR=./.data
# AI_DESK_USE_LLM=auto

# --- Document service (port 8092 — PDF/Word + embeddings, no local LLM) ---
# DOCUMENT_SERVICE_URL=http://127.0.0.1:8092
